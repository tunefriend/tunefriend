    <exclude domain="sharedpref" path="tunefriend_secure_prefs" />
    <exclude domain="sharedpref" path="tunefriend_auto_library_secure.xml" />
    <exclude domain="sharedpref" path="tunefriend_auto_library_secure" />
    <exclude domain="sharedpref" path="tunefriend_auto_library.xml" />
    <exclude domain="sharedpref" path="tunefriend_auto_library" />
</full-backup-content>
